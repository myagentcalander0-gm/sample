{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Streamlit: Run app.py (debug)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "streamlit",
      "args": ["run", "app.py", "--server.port", "8501"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "subProcess": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "DEPLOYMENT_ENV": "dev"
      }
    }
  ]
}
